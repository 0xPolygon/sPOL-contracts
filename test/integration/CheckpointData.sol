pragma solidity ^0.8.0;

/// @notice Shared checkpoint data for integration tests that fork from mainnet.
///         Contains RootChain.submitCheckpoint() calldata from real checkpoint transactions
///         and the L1 block to fork from (one block before the first checkpoint).
///         Update these when the rpc prunes the old state.
///
///         Last updated: 2026-03-19
///         L1 fork block: 24692715 (one before checkpoint at 24692716)
///         Checkpoint tx 1: 0xd5c8f34c55609600429e1a0a4c5feca80bdca1aa445b6a7fb0b6d2b13c62038d (block 24692716)
///         Checkpoint tx 2: 0x7e86bd40928473e4aaa6a4e3fc691ff3cd135f567eeea5252606d2ee2e2576da (block 24692773)
abstract contract CheckpointData {
    uint256 constant FORK_BLOCK_L1 = 24692715;
    address constant ROOT_CHAIN = 0x86E4Dc95c7FBdBf52e33D563BbDB00823894C287;

    function _submitCheckpoint1() internal {
        (bool _success,) = ROOT_CHAIN.call(rewardIncreaseCall1);
        require(_success, "Checkpoint 1 submission failed");
    }

    function _submitCheckpoint2() internal {
        (bool _success,) = ROOT_CHAIN.call(rewardIncreaseCall2);
        require(_success, "Checkpoint 2 submission failed");
    }

    // checkSignatures calldata from checkpoint tx 1
    bytes rewardIncreaseCall1 =
        hex"";

    // checkSignatures calldata from checkpoint tx 2
    bytes rewardIncreaseCall2 =
        hex"";
}
